{
  "name": "shri-ai",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "rag:embed": "npx tsx scripts/embed-scriptures.ts",
    "rag:evaluate": "npx tsx scripts/evaluate-retrieval.ts",
    "lint": "eslint --max-warnings=0",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:check": "node scripts/check-db.mjs",
    "db:capabilities": "node scripts/check-db-capabilities.mjs",
    "db:ready": "node scripts/verify-db-readiness.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "scripture:build-corpus": "node scripts/build-besant-gita-corpus.mjs",
    "scripture:validate": "tsx scripts/validate-scriptures.ts",
    "scripture:ingest": "tsx scripts/ingest-scriptures.ts",
    "scripture:embed": "tsx scripts/embed-scriptures.ts",
    "scripture:eval": "tsx scripts/evaluate-scripture-retrieval.ts",
    "scripture:prepare-reviews": "tsx scripts/prepare-scripture-reviews.ts",
    "release:check": "tsx scripts/check-release-readiness.ts",
    "release:verify:local": "npm run db:ready && npm run scripture:validate && tsx scripts/check-local-ai-readiness.ts && npm run scripture:eval && npm run release:check",
    "source:archive": "node scripts/create-source-archive.mjs",
    "source:archive:verify": "node scripts/verify-source-archive.mjs",
    "voice:qa:create": "tsx scripts/create-voice-qa-run.ts",
    "secrets:check": "node scripts/check-secret-containment.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "bcryptjs": "^3.0.3",
    "mammoth": "^1.12.0",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13",
    "hono": "^4.12.25"
  }
}
