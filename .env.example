# Option A: local Postgres installed on your machine.
# Create the database first, then use a URL like this:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shri_ai?schema=public"

# Option B: remote Postgres.
# Replace DATABASE_URL with your provider URL, keeping ?schema=public when supported.
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

AUTH_SECRET="replace-with-a-random-32-byte-secret"

# ── Local AI ────────────────────────────────────────────────────────────────
# Ollama is accessed only by server code. No API key is required.
OLLAMA_BASE_URL="http://127.0.0.1:11434"
SHRI_AI_CHAT_MODEL="qwen3:8b"
SHRI_AI_EMBEDDING_MODEL="qwen3-embedding:0.6b"
SHRI_AI_EMBEDDING_DIMENSIONS="1024"
SHRI_AI_CHAT_TIMEOUT_MS="120000"
SHRI_AI_EMBEDDING_TIMEOUT_MS="30000"

# ── Local Voice ─────────────────────────────────────────────────────────────
# The private faster-whisper service accepts authenticated multipart uploads at
# POST /v1/transcriptions. Generate the shared backend/service token with:
# openssl rand -hex 32
STT_BASE_URL="http://127.0.0.1:8001"
STT_MODEL="small"
STT_TIMEOUT_MS="100000"
STT_SERVICE_TOKEN="replace-with-at-least-32-random-characters"
# Speech output uses the browser's local SpeechSynthesis engine only.

# ── Scripture Review Authorization ──────────────────────────────────────────
# Comma-separated emails allowed to access the scripture review console.
# ADMIN_EMAILS may also review and view audit history.
REVIEWER_EMAILS=""
ADMIN_EMAILS=""

# ── Release Readiness Gates ─────────────────────────────────────────────────
RELEASE_ENVIRONMENT="staging"
RELEASE_MIN_VOICE_APPROVED_CHUNKS="1"
RELEASE_MIN_VOICE_APPROVED_PERCENT="1"
RELEASE_REQUIRE_COMPLETED_VOICE_QA="true"

# ── OM Ambient Audio ────────────────────────────────────────────────────────
# Place your OM audio file at: public/audio/om.mp3
# The file is NOT included in the repo. Download or record a looping OM chant.
# If the file is missing, the OM toggle is simply disabled — the app does not crash.
# Audio only starts after the user's first click (browser autoplay policy).
