# Copy this file to .env.local for local development.
# Never commit .env, .env.local, production env files, or real secret values.

# ── Database ─────────────────────────────────────────────────────────────────
# Local Postgres example. Replace username/password/host/database for your setup.
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/shri_ai?schema=public"

# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-random-32-byte-secret"

# ── AI Chat / Embeddings ─────────────────────────────────────────────────────
# Current implementation uses the OpenAI provider. Leave empty to make AI calls fail safely.
OPENAI_API_KEY=""
AI_CHAT_MODEL="gpt-5-mini"
AI_TEXT_MODEL="gpt-5-mini"
AI_EMBEDDING_MODEL="text-embedding-3-small"
AI_EMBEDDING_DIMENSIONS="1536"

# ── Voice / Speech-to-Text ──────────────────────────────────────────────────
# Supported values: openai, deepgram, google.
# If the selected provider key is missing, voice transcription must return a safe error.
STT_PROVIDER="openai"
DEEPGRAM_API_KEY=""
GOOGLE_API_KEY=""

# ── Voice / Text-to-Speech ──────────────────────────────────────────────────
# Optional. Leave empty unless explicitly configuring TTS outside source control.
ELEVENLABS_API_KEY=""

# ── Scripture Review Authorization ──────────────────────────────────────────
# Comma-separated emails only. Keep blank until reviewers/admins are configured.
REVIEWER_EMAILS=""
ADMIN_EMAILS=""

# ── Release Readiness Gates ─────────────────────────────────────────────────
RELEASE_ENVIRONMENT="staging"
RELEASE_MIN_VOICE_APPROVED_CHUNKS="1"
RELEASE_MIN_VOICE_APPROVED_PERCENT="1"
RELEASE_REQUIRE_COMPLETED_VOICE_QA="true"

# ── OM Ambient Audio ────────────────────────────────────────────────────────
# Place your OM audio file at: public/audio/om.mp3
# The file is NOT included in the repo.
