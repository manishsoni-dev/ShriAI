generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String              @id @default(cuid())
  supabaseAuthUserId         String?             @unique @db.Uuid
  email                      String              @unique
  name                       String?
  imageUrl                   String?
  passwordHash               String
  workspaceMember            WorkspaceMember[]
  conversations              Conversation[]
  usageEvents                UsageEvent[]
  feedbacks                  UserFeedback[]
  uploadedDocuments          Document[]          @relation("DocumentUploadedBy")
  languagePreference         String              @default("auto")
  /// Tradition/source scope preference for retrieval filtering (e.g. "vaishnava", "shaiva", "universal", "any")
  sourceScope                String              @default("any")
  microphoneConsentGivenAt   DateTime?
  microphoneConsentVersion   String?
  onboardedAt                DateTime?
  researchConsentGivenAt     DateTime?
  researchConsentVersion     String?
  researchConsentWithdrawnAt DateTime?
  studyModeEnabled           Boolean             @default(false)
  savedAnswers               SavedAnswer[]
  reflections                Reflection[]
  productEvents              ProductEvent[]
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt
  betaInvite                 BetaInvite?         @relation("UserBetaInvite")
  sentInvites                BetaInvite[]        @relation("Inviter")
  supportTickets             BetaSupportTicket[]
}

model BetaInvite {
  id         String    @id @default(cuid())
  email      String    @unique
  inviterId  String?
  status     String    @default("pending") // pending, accepted, revoked, expired
  expiresAt  DateTime?
  acceptedAt DateTime?
  userId     String?   @unique

  user    User? @relation("UserBetaInvite", fields: [userId], references: [id])
  inviter User? @relation("Inviter", fields: [inviterId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
}

model Workspace {
  id             String            @id @default(cuid())
  name           String
  slug           String            @unique
  members        WorkspaceMember[]
  conversations  Conversation[]
  usageEvents    UsageEvent[]
  documents      Document[]
  documentChunks DocumentChunk[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
}

model WorkspaceMember {
  id          String        @id @default(cuid())
  role        WorkspaceRole @default(MEMBER)
  userId      String
  workspaceId String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

model Conversation {
  id          String         @id @default(cuid())
  title       String?
  metadata    Json?
  workspaceId String
  userId      String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages    Message[]
  usageEvents UsageEvent[]
  feedbacks   UserFeedback[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([workspaceId])
  @@index([userId])
  @@index([createdAt])
  @@index([workspaceId, userId, createdAt])
}

model Message {
  id             String           @id @default(cuid())
  role           MessageRole
  content        String
  metadata       Json?
  conversationId String
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  citations      AnswerCitation[]
  feedbacks      UserFeedback[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([conversationId])
  @@index([createdAt])
  @@index([conversationId, createdAt])
}

enum MessageRole {
  user
  assistant
  system
  tool
}

model UsageEvent {
  id             String           @id @default(cuid())
  userId         String
  workspaceId    String
  conversationId String?
  provider       String
  model          String
  inputTokens    Int              @default(0)
  outputTokens   Int              @default(0)
  totalTokens    Int              @default(0)
  latencyMs      Int
  status         UsageEventStatus
  errorCode      String?
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation   Conversation?    @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())

  @@index([userId])
  @@index([workspaceId])
  @@index([conversationId])
  @@index([createdAt])
  @@index([workspaceId, createdAt])
}

enum UsageEventStatus {
  success
  error
}

/// Flexible trace events for voice, retrieval, chat, and TTS diagnostics.
model ObservabilityEvent {
  id             String   @id @default(cuid())
  traceId        String
  eventType      String
  status         String
  userId         String?
  conversationId String?
  messageId      String?
  personaId      String?
  model          String?
  latencyMs      Int?
  payload        Json?
  createdAt      DateTime @default(now())

  @@index([traceId])
  @@index([eventType])
  @@index([status])
  @@index([createdAt])
  @@index([userId])
  @@index([conversationId])
}

enum VoiceQaRunStatus {
  pending
  passed
  failed
  partial
  invalid
}

enum VoiceQaStepStatus {
  pending
  passed
  failed
  skipped
}

enum VoiceQaEvidenceSource {
  manual
  automated_fixture
}

model VoiceQaRun {
  id             String                @id @default(cuid())
  label          String
  device         String?
  browser        String?
  personaId      String?
  status         VoiceQaRunStatus      @default(pending)
  evidenceSource VoiceQaEvidenceSource @default(manual)
  notes          String?
  startedAt      DateTime              @default(now())
  completedAt    DateTime?
  invalidatedAt  DateTime?
  steps          VoiceQaStep[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  @@index([status])
  @@index([evidenceSource])
  @@index([personaId])
  @@index([startedAt])
}

model VoiceQaStep {
  id                 String            @id @default(cuid())
  runId              String
  stepType           String
  status             VoiceQaStepStatus @default(pending)
  transcript         String?
  expectedTranscript String?
  wer                Float?
  latencyMs          Int?
  firstAudibleMs     Int?
  errorCode          String?
  notes              String?
  payload            Json?
  run                VoiceQaRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([runId])
  @@index([stepType])
  @@index([status])
}

model WaitlistLead {
  id        String   @id @default(cuid())
  email     String
  name      String?
  interest  String?
  message   String?
  source    String   @default("waitlist")
  createdAt DateTime @default(now())

  @@index([email])
  @@index([createdAt])
}

model Document {
  id           String          @id @default(cuid())
  filename     String
  contentType  String
  size         Int
  storageKey   String          @unique
  status       DocumentStatus  @default(uploaded)
  uploadedById String
  workspaceId  String
  uploadedBy   User            @relation("DocumentUploadedBy", fields: [uploadedById], references: [id], onDelete: Cascade)
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks       DocumentChunk[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt

  @@index([workspaceId])
  @@index([uploadedById])
  @@index([createdAt])
  @@index([workspaceId, createdAt])
}

enum DocumentStatus {
  uploaded
  processing
  ready
  failed
}

model DocumentChunk {
  id                   String                       @id @default(cuid())
  documentId           String
  workspaceId          String
  sourceId             String?
  scriptureName        String?
  chapter              Int?
  verseStart           Int?
  verseEnd             Int?
  language             String?
  chunkIndex           Int
  content              String
  normalizedText       String?
  tokenCount           Int?
  chunkHash            String?
  metadata             Json?
  reviewStatus         ScriptureReviewStatus        @default(pending)
  embedding            Unsupported("vector(1024)")?
  embeddingProvider    String?
  embeddingModel       String?
  embeddingDimensions  Int?
  embeddingVersion     String?
  embeddingGeneratedAt DateTime?
  document             Document                     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  workspace            Workspace                    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  @@unique([documentId, chunkIndex])
  @@index([documentId])
  @@index([workspaceId])
  @@index([workspaceId, documentId])
}

// ── Scripture RAG Models ────────────────────────────────────────────────────

/// One canonical text (e.g. "Bhagavad Gita"). Priority 1–10 (10 = most authoritative).
model ScriptureSource {
  id                             String                @id @default(cuid())
  /// e.g. "Bhagavad Gita", "Valmiki Ramayana"
  canonicalTitle                 String                @unique
  sourceName                     String?
  /// e.g. "Vaishnava", "Shaiva", "Universal"
  tradition                      String
  /// Primary language of the original text
  language                       String                @default("sanskrit")
  /// "public_domain", "licensed", "fair_use"
  copyrightStatus                String                @default("public_domain")
  manifestId                     String?               @unique
  edition                        String?
  translator                     String?
  licenseOrUsageBasis            String?
  attributionText                String?
  sourceUrlOrProvenanceReference String?
  ingestionDate                  DateTime?
  reviewStatus                   ScriptureReviewStatus @default(pending)
  reviewedBy                     String?
  reviewedAt                     DateTime?
  /// 1–10 — used to boost retrieval score (10 = highest priority)
  priority                       Int                   @default(5)
  /// Source-level eligibility switch for production retrieval.
  active                         Boolean               @default(true)
  chunks                         ScriptureChunk[]
  createdAt                      DateTime              @default(now())
  updatedAt                      DateTime              @updatedAt

  @@index([tradition])
  @@index([priority])
  @@index([active])
}

/// One verse, doha, passage, or thematic chunk from a scripture source.
model ScriptureChunk {
  id                   String                       @id @default(cuid())
  sourceId             String
  documentId           String?
  workspaceId          String?
  scriptureName        String?
  /// Canonical reference string, e.g. "2.47", "Sundara Kanda 1.1"
  canonicalRef         String
  chapter              Int                          @default(1)
  verseStart           Int                          @default(1)
  verseEnd             Int                          @default(1)
  /// Primary language of the originalText field
  language             String                       @default("sanskrit")
  /// Devanagari / original script
  originalText         String?
  /// IAST / ISO 15919 transliteration
  transliteration      String?
  /// English translation
  translation          String
  normalizedText       String?
  tokenCount           Int?
  chunkHash            String?
  /// Scholarly or devotional commentary
  commentary           String?
  /// Practical application — used in answer planning
  practicalNote        String?
  /// Persona IDs this chunk is primarily associated with (e.g. ["krishna"])
  personaTags          String[]
  /// Thematic tags (e.g. ["karma", "duty", "detachment"])
  themeTags            String[]
  /// Emotional/situational tags (e.g. ["confusion", "grief", "fear_of_failure"])
  emotionTags          String[]
  /// Use-case labels (e.g. ["career confusion", "dealing with loss"])
  answerUseCases       String[]
  /// Local Ollama embedding of translation + commentary combined
  embedding            Unsupported("vector(1024)")?
  embeddingProvider    String?
  embeddingModel       String?
  embeddingDimensions  Int?
  embeddingVersion     String?
  embeddingGeneratedAt DateTime?
  embeddingCorpusHash  String?
  embeddingNormalized  Boolean?
  /// PostgreSQL full-text search vector (auto-maintained by DB trigger)
  searchVector         Unsupported("tsvector")?
  source               ScriptureSource              @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  citations            AnswerCitation[]
  reviews              ScriptureChunkReview[]
  reviewAudits         ScriptureChunkReviewAudit[]
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  @@unique([sourceId, canonicalRef])
  @@index([sourceId])
  @@index([personaTags])
  @@index([themeTags])
  @@index([chapter, verseStart, verseEnd])
}

enum ScriptureReviewStatus {
  pending
  in_review
  approved
  rejected
  needs_changes
  needs_revision
}

/// Human theological/source review for a scripture chunk before broad voice use.
model ScriptureChunkReview {
  id                  String                      @id @default(cuid())
  chunkId             String                      @unique
  reviewStatus        ScriptureReviewStatus       @default(pending)
  reviewOrigin        String                      @default("human")
  reviewedBy          String?
  reviewedAt          DateTime?
  invalidatedAt       DateTime?
  invalidationReason  String?
  accuracyScore       Int?
  interpretationNotes String?
  rejectionReason     String?
  approvedForVoice    Boolean                     @default(false)
  chunk               ScriptureChunk              @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  audits              ScriptureChunkReviewAudit[]
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@index([reviewStatus])
  @@index([approvedForVoice])
  @@index([reviewedAt])
}

/// Immutable audit trail for scripture chunk review decisions.
model ScriptureChunkReviewAudit {
  id                       String                 @id @default(cuid())
  reviewId                 String
  scriptureChunkId         String
  previousStatus           ScriptureReviewStatus?
  nextStatus               ScriptureReviewStatus
  previousApprovedForVoice Boolean?
  nextApprovedForVoice     Boolean
  reviewerUserId           String
  notes                    String?
  review                   ScriptureChunkReview   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  scriptureChunk           ScriptureChunk         @relation(fields: [scriptureChunkId], references: [id], onDelete: Cascade)
  createdAt                DateTime               @default(now())

  @@index([reviewId])
  @@index([scriptureChunkId])
  @@index([reviewerUserId])
  @@index([createdAt])
}

/// Debug log: every scripture retrieval attempt. Used for improving retrieval quality.
model RetrievalLog {
  id                String   @id @default(cuid())
  query             String
  personaId         String
  retrievedChunkIds String[]
  selectedChunkIds  String[]
  latencyMs         Int
  sourceFilter      String[]
  resultCount       Int      @default(0)
  createdAt         DateTime @default(now())

  @@index([personaId])
  @@index([createdAt])
}

/// Links a Message to the ScriptureChunks cited in the response.
model AnswerCitation {
  id        String         @id @default(cuid())
  messageId String
  chunkId   String
  score     Float?
  chunk     ScriptureChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  message   Message        @relation(fields: [messageId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now())

  @@index([messageId])
  @@index([chunkId])
}

enum FeedbackLabel {
  helpful
  not_helpful
  citation_issue
  unsafe
  confusing
}

/// Privacy-safe user feedback on model responses.
model UserFeedback {
  id                     String          @id @default(cuid())
  userId                 String
  conversationId         String
  messageId              String
  personaId              String?
  traceId                String?
  modelConfiguration     String?
  retrievalConfiguration String?
  labels                 FeedbackLabel[]
  notes                  String? // optional free-text
  triageStatus           String          @default("new") // new, investigating, accepted, fixed, cannot_reproduce, rejected, duplicate

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([conversationId])
  @@index([messageId])
}

model BetaSupportTicket {
  id              String   @id @default(cuid())
  userId          String
  issueCategory   String
  traceId         String?
  timestamp       DateTime @default(now())
  browser         String?
  os              String?
  deviceClass     String?
  persona         String?
  interactionMode String?
  description     String
  status          String   @default("open") // open, investigating, resolved, closed

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Phase 5: User-value loop models ────────────────────────────────────────

/// A user-saved assistant answer for later reference. Private to user + workspace.
model SavedAnswer {
  id             String       @id @default(cuid())
  userId         String
  workspaceId    String
  conversationId String
  messageId      String
  personaId      String?
  /// Snapshot of the answer content at save time (not updated if the message changes)
  answerSnapshot String
  /// Number of citations on the answer at save time
  citationCount  Int          @default(0)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  reflections    Reflection[]
  createdAt      DateTime     @default(now())

  @@index([userId])
  @@index([workspaceId])
  @@index([userId, workspaceId])
  @@index([messageId])
}

/// A private user reflection attached to a saved answer. Never used in analytics.
model Reflection {
  id            String      @id @default(cuid())
  userId        String
  savedAnswerId String
  /// User-authored note text — private, never logged to analytics
  body          String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  savedAnswer   SavedAnswer @relation(fields: [savedAnswerId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([savedAnswerId])
}

/// Privacy-safe internal product analytics events. Raw prompt, answer, or audio MUST NOT be stored here.
model ProductEvent {
  id          String   @id @default(cuid())
  eventType   String
  userId      String?
  workspaceId String?
  personaId   String?
  traceId     String?
  /// Safe structured metadata only — no raw question/answer text
  metadata    Json?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([eventType])
  @@index([userId])
  @@index([workspaceId])
  @@index([createdAt])
}

/// Internal tracking for usability testing defects and blockers
model UsabilityDefect {
  id                String   @id @default(cuid())
  /// "blocker" | "high" | "medium" | "low"
  severity          String
  workflowStage     String
  reproductionSteps String
  affectedDevice    String?
  /// Reference to ProductEvent traceId or id
  linkedEventId     String?
  /// "open" | "investigating" | "resolved" | "closed"
  resolutionStatus  String   @default("open")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([severity])
  @@index([resolutionStatus])
}

/// Server-side feature flags for beta rollout control
model FeatureFlag {
  name        String   @id // e.g. "voice_input", "document_upload"
  enabled     Boolean  @default(false)
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String? // Admin userId who last toggled it
}
